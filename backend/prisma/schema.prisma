generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  loans        Loan[]
  ratings      BookRating[]
  reservations Reservation[]
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique // ADMIN, SUBADMIN, BIBLIOTECARIO, CLIENTE, PROFESOR, ESTUDIANTE, INVITADO
  description String?
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Author {
  id        Int     @id @default(autoincrement())
  name      String
  biography String?
  books     Book[]
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  books       Book[]
}

model Book {
  id              Int      @id @default(autoincrement())
  title           String
  isbn            String   @unique
  description     String?
  publicationYear Int?
  publisher       String?
  stock           Int      @default(1)
  available       Boolean  @default(true)
  imageUrl        String?
  createdAt       DateTime @default(now())

  authorId Int
  author   Author @relation(fields: [authorId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  copies       BookCopy[]
  loans        Loan[]
  ratings      BookRating[]
  reservations Reservation[]
}

model BookCopy {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  status    String   @default("DISPONIBLE") // DISPONIBLE, PRESTADO, DAÑADO, PERDIDO, MANTENIMIENTO
  location  String?
  createdAt DateTime @default(now())

  bookId Int
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  loans Loan[]
}

model Loan {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  bookId Int
  book   Book @relation(fields: [bookId], references: [id])

  bookCopyId Int?
  bookCopy   BookCopy? @relation(fields: [bookCopyId], references: [id])

  loanDate   DateTime  @default(now())
  dueDate    DateTime?
  returnDate DateTime?

  status String @default("Pendiente") // Pendiente, Activo, Devuelto, Cancelado, Vencido, Renovacion pendiente, Devuelto con retraso, Rechazado

  documentType     String?
  baseCost         Decimal @default(0) @db.Decimal(10, 2)
  discountPercent  Decimal @default(0) @db.Decimal(10, 2)
  finalCost        Decimal @default(0) @db.Decimal(10, 2)
  fineAmount       Decimal @default(0) @db.Decimal(10, 2)
  renewalRequested Boolean @default(false)

  approvedById         Int?
  returnRegisteredById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BookRating {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  bookId Int
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  rating  Int
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId])
}

model Reservation {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  bookId Int
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  status      String    @default("PENDIENTE") // PENDIENTE, DISPONIBLE
  createdAt   DateTime  @default(now())
  fulfilledAt DateTime?
}

model AuditoriaLog {
  id          Int      @id @default(autoincrement())
  actorId     Int?
  actorNombre String?
  accion      String
  entidad     String
  entidadId   Int?
  detalle     String?
  createdAt   DateTime @default(now())
}
